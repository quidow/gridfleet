{
  "name": "gridfleet-frontend",
  "private": true,
  "version": "0.1.0",
  "description": "React operator UI for GridFleet",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/quidow/gridfleet.git",
    "directory": "frontend"
  },
  "bugs": {
    "url": "https://github.com/quidow/gridfleet/issues"
  },
  "homepage": "https://github.com/quidow/gridfleet#readme",
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run test:e2e:mocked && npm run test:e2e:live",
    "test:e2e:mocked": "node scripts/run-playwright.mjs test --config playwright.config.ts",
    "test:e2e:live": "node scripts/run-playwright.mjs test --config playwright.live.config.ts",
    "openapi:dump": "cd ../backend && uv run python -m app.scripts.dump_openapi --out ../frontend/openapi.json",
    "openapi:generate": "openapi-typescript ./openapi.json --output ./src/api/openapi.ts",
    "types:generate": "npm run openapi:dump && npm run openapi:generate",
    "types:check": "npm run types:generate && git diff --exit-code -- src/api/openapi.ts"
  },
  "dependencies": {
    "@fontsource-variable/ibm-plex-sans": "^5.2.8",
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.100.10",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "axios": "^1.16.1",
    "lucide-react": "^1.16.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "knip": "^6.13.1",
    "openapi-typescript": "^7.13.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  },
  "overrides": {
    "dompurify": "^3.4.1"
  }
}
