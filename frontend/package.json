{
  "name": "gridfleet-frontend",
  "private": true,
  "version": "0.6.0",
  "description": "React operator UI for GridFleet",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/quidow/gridfleet.git",
    "directory": "frontend"
  },
  "bugs": {
    "url": "https://github.com/quidow/gridfleet/issues"
  },
  "homepage": "https://github.com/quidow/gridfleet#readme",
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run test:e2e:mocked && npm run test:e2e:live",
    "test:e2e:mocked": "node scripts/run-playwright.mjs test --config playwright.config.ts",
    "test:e2e:live": "node scripts/run-playwright.mjs test --config playwright.live.config.ts",
    "test:e2e:compose": "node scripts/run-playwright.mjs test --config playwright.compose.config.ts",
    "openapi:dump": "cd ../backend && uv run python -m app.scripts.dump_openapi --out ../frontend/openapi.json",
    "openapi:generate": "openapi-typescript ./openapi.json --output ./src/api/openapi.ts",
    "types:generate": "npm run openapi:dump && npm run openapi:generate",
    "types:check": "npm run types:generate && git diff --exit-code -- src/api/openapi.ts"
  },
  "dependencies": {
    "@fontsource-variable/ibm-plex-sans": "^5.3.0",
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/vite": "^4.3.3",
    "@tanstack/react-query": "^5.101.3",
    "axios": "^1.18.1",
    "lucide-react": "^1.25.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.10.0",
    "sonner": "^2.0.7",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^9.39.5",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.39.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "knip": "^6.27.0",
    "openapi-typescript": "^7.13.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "dompurify": "^3.4.12",
    "js-yaml": "^4.2.0",
    "openapi-typescript": {
      "typescript": "$typescript"
    }
  }
}
