{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "separate-pull-requests": true,
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": false,
  "packages": {
    "backend": {
      "release-type": "python",
      "package-name": "gridfleet-backend",
      "include-component-in-tag": true
    },
    "agent": {
      "release-type": "python",
      "package-name": "gridfleet-agent",
      "include-component-in-tag": true
    },
    "frontend": {
      "release-type": "node",
      "package-name": "gridfleet-frontend",
      "include-component-in-tag": true
    },
    "testkit": {
      "release-type": "python",
      "package-name": "gridfleet-testkit",
      "include-component-in-tag": true
    }
  }
}
