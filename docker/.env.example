# Copy this file to docker/.env before starting the production stack.
# Keep POSTGRES_* and GRIDFLEET_DATABASE_URL aligned.

COMPOSE_PROJECT_NAME=gridfleet

# Published ports
BACKEND_PORT=8000
FRONTEND_PORT=3000
GRID_PUBLISH_PORT=4442
GRID_SUBSCRIBE_PORT=4443
GRID_HUB_PORT=4444

# Postgres container configuration
POSTGRES_USER=gridfleet
POSTGRES_PASSWORD=change-me-now
POSTGRES_DB=gridfleet
POSTGRES_MAX_CONNECTIONS=200

# Backend core process configuration
GRIDFLEET_DATABASE_URL=postgresql+asyncpg://gridfleet:change-me-now@postgres:5432/gridfleet
GRIDFLEET_DB_POOL_SIZE=10
GRIDFLEET_DB_MAX_OVERFLOW=20
GRIDFLEET_REQUEST_TIMEOUT_SEC=30
GRIDFLEET_ENV=production
GRIDFLEET_AUTH_ENABLED=true
GRIDFLEET_AUTH_SESSION_TTL_SEC=28800
GRIDFLEET_AUTH_COOKIE_SECURE=true
GRIDFLEET_AUTH_USERNAME=operator
GRIDFLEET_AUTH_PASSWORD=change-me
GRIDFLEET_AUTH_SESSION_SECRET=replace-with-a-long-random-secret
GRIDFLEET_MACHINE_AUTH_USERNAME=gridfleet-machine
GRIDFLEET_MACHINE_AUTH_PASSWORD=change-me
# Optional: credentials the backend uses when calling agent APIs (leave empty to disable).
GRIDFLEET_AGENT_AUTH_USERNAME=
GRIDFLEET_AGENT_AUTH_PASSWORD=

# Backend settings-registry fallback environment variables
GRIDFLEET_GRID_HUB_URL=http://selenium-hub:4444
GRIDFLEET_HEARTBEAT_INTERVAL_SEC=15
GRIDFLEET_MAX_MISSED_HEARTBEATS=3
GRIDFLEET_NODE_CHECK_INTERVAL_SEC=30
GRIDFLEET_NODE_MAX_FAILURES=3
GRIDFLEET_DEVICE_CHECK_INTERVAL_SEC=60
GRIDFLEET_SESSION_QUEUE_TIMEOUT_SEC=300
GRIDFLEET_PROPERTY_REFRESH_INTERVAL_SEC=600
GRIDFLEET_APPIUM_PORT_RANGE_START=4723
GRIDFLEET_APPIUM_PORT_RANGE_END=4823
GRIDFLEET_MIN_AGENT_VERSION=0.1.0
GRIDFLEET_HOST_AUTO_ACCEPT=false
GRIDFLEET_ENABLE_WEB_TERMINAL=false
# Required when GRIDFLEET_ENABLE_WEB_TERMINAL=true and auth is enabled.
GRIDFLEET_AGENT_TERMINAL_TOKEN=
GRIDFLEET_WEB_TERMINAL_ALLOWED_ORIGINS=
GRIDFLEET_RESERVATION_CLAIM_TTL_SECONDS=120
GRIDFLEET_RUN_REAPER_INTERVAL_SEC=15

# Agent runtime environment variables
# These are not consumed by the production compose file directly.
# Copy them into the agent host environment file or service definition.
AGENT_MANAGER_URL=http://manager.example.com:8000
AGENT_REGISTRATION_REFRESH_INTERVAL_SEC=30
AGENT_MANAGER_AUTH_USERNAME=gridfleet-machine
AGENT_MANAGER_AUTH_PASSWORD=change-me
AGENT_AGENT_PORT=5100
AGENT_GRID_HUB_URL=http://manager.example.com:4444
AGENT_GRID_PUBLISH_URL=tcp://manager.example.com:4442
AGENT_GRID_SUBSCRIBE_URL=tcp://manager.example.com:4443
AGENT_SELENIUM_SERVER_JAR=/opt/gridfleet-agent/selenium-server.jar
AGENT_RUNTIME_ROOT=/opt/gridfleet-agent/runtimes
AGENT_APPIUM_PORT_RANGE_START=4723
AGENT_APPIUM_PORT_RANGE_END=4823
AGENT_GRID_NODE_PORT_START=5555
AGENT_ADB_RECONNECT_PORT=5555
AGENT_ENABLE_WEB_TERMINAL=false
AGENT_TERMINAL_TOKEN=
AGENT_TERMINAL_SHELL=
# AGENT_ADVERTISE_IP=10.0.0.25

# Optional external testkit / CI variables
GRID_URL=http://manager.example.com:4444
GRIDFLEET_API_URL=http://manager.example.com:8000/api
